{
  "name": "kickoff-fm",
  "version": "0.1.0",
  "description": "Kick-Off FM — physical-agent football match engine + online manager (in development).",
  "type": "module",
  "scripts": {
    "sim": "node scripts/sim.js",
    "bench": "node scripts/sim.js --benchmark 16",
    "server": "node --env-file=.env server/index.js",
    "server:dev": "node --env-file=.env --watch server/index.js",
    "seed": "node --env-file=.env scripts/seed.js"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/static": "^7.0.0",
    "@fastify/websocket": "^10.0.0",
    "argon2": "^0.40.0",
    "fastify": "^4.28.0",
    "fastify-plugin": "^5.1.0",
    "mongoose": "^8.5.0",
    "node-telegram-bot-api": "^0.66.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3"
  }
}
