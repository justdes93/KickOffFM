# Copy to .env and fill in values. Never commit .env.
NODE_ENV=development
PORT=3000

# MongoDB Atlas (free tier M0) — get from https://cloud.mongodb.com/
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/kickoff-fm

# JWT signing key for sessions — generate via:  openssl rand -hex 32
JWT_SECRET=replace-with-openssl-rand-hex-32

# Telegram bot for 2FA — get from @BotFather, then revoke + replace if leaked
TELEGRAM_BOT_TOKEN=

# Beta-key gate for friend testing — anyone registering must enter this code
BETA_KEY=letmein

# Public URL for emails / Telegram callbacks once deployed
PUBLIC_URL=http://localhost:3000
